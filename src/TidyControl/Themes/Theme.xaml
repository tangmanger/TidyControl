<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- ==============================================
    【分层说明】
    1. MergedDictionaries 运行时由 ThemeManager 动态注入 Colors.Light.xaml / Colors.Dark.xaml
    2. 全部Token采用原生 Color="{DynamicResource 底层色阶}" 实现中转，无第三方扩展属性
    3. 上层控件样式仅引用本文件语义Key，禁止直接使用 Primary1/Gray7 等底层色键
    4. 色彩规则统一：常态=6阶、Hover=5阶、Active=7阶、Pressed=8阶、浅背景=1阶
    ============================================== -->
    <ResourceDictionary.MergedDictionaries>
        <!-- 占位空字典，后台代码替换对应主题色板 -->
        <ResourceDictionary Source="/TidyControl;component/Colors/Colors.Light.xaml"/>
    </ResourceDictionary.MergedDictionaries>

    <!-- ====================== 品牌主色 Primary Token ====================== -->
    <!-- 主色常态：主按钮、复选框、输入框聚焦边框标准色 -->
    <SolidColorBrush x:Key="ColorPrimary" Color="{DynamicResource Primary6}"/>
    <!-- 主色悬浮：鼠标移入控件 Hover 状态 -->
    <SolidColorBrush x:Key="ColorPrimaryHover" Color="{DynamicResource Primary5}"/>
    <!-- 主色激活：点击、IsFocused 激活态 -->
    <SolidColorBrush x:Key="ColorPrimaryActive" Color="{DynamicResource Primary7}"/>
    <!-- 主色按压：长按、持续按下深色 -->
    <SolidColorBrush x:Key="ColorPrimaryPressed" Color="{DynamicResource Primary8}"/>
    <!-- 主色浅底色：标签背景、表格选中行背景 -->
    <SolidColorBrush x:Key="ColorPrimaryBg" Color="{DynamicResource Primary1}"/>

    <!-- ====================== 成功色 Success Token ====================== -->
    <SolidColorBrush x:Key="ColorSuccess" Color="{DynamicResource Success6}"/>
    <SolidColorBrush x:Key="ColorSuccessHover" Color="{DynamicResource Success5}"/>
    <SolidColorBrush x:Key="ColorSuccessActive" Color="{DynamicResource Success7}"/>
    <SolidColorBrush x:Key="ColorSuccessBg" Color="{DynamicResource Success1}"/>

    <!-- ====================== 警告色 Warning Token ====================== -->
    <SolidColorBrush x:Key="ColorWarning" Color="{DynamicResource Warning6}"/>
    <SolidColorBrush x:Key="ColorWarningHover" Color="{DynamicResource Warning5}"/>
    <SolidColorBrush x:Key="ColorWarningActive" Color="{DynamicResource Warning7}"/>
    <SolidColorBrush x:Key="ColorWarningBg" Color="{DynamicResource Warning1}"/>

    <!-- ====================== 危险/错误色 Danger Token ====================== -->
    <SolidColorBrush x:Key="ColorDanger" Color="{DynamicResource Danger6}"/>
    <SolidColorBrush x:Key="ColorDangerHover" Color="{DynamicResource Danger5}"/>
    <SolidColorBrush x:Key="ColorDangerActive" Color="{DynamicResource Danger7}"/>
    <SolidColorBrush x:Key="ColorDangerBg" Color="{DynamicResource Danger1}"/>

    <!-- ====================== 文本分级Token（全局文字统一规范） ====================== -->
    <!-- 一级标题、表头、强强调文字 -->
    <SolidColorBrush x:Key="TextPrimary" Color="{DynamicResource Gray9}"/>
    <!-- 正文、表单常规内容 -->
    <SolidColorBrush x:Key="TextRegular" Color="{DynamicResource Gray7}"/>
    <!-- 辅助说明、备注、次要提示文字 -->
    <SolidColorBrush x:Key="TextSecondary" Color="{DynamicResource Gray6}"/>
    <!-- 输入框占位水印、全局禁用文字 -->
    <SolidColorBrush x:Key="TextPlaceholder" Color="{DynamicResource Gray5}"/>
    <!-- 彩色按钮内部白色文字 -->
    <SolidColorBrush x:Key="TextInverse" Color="{DynamicResource Gray0}"/>

    <!-- ====================== 页面/容器背景Token ====================== -->
    <!-- 程序根页面背景 -->
    <SolidColorBrush x:Key="BgPage" Color="{DynamicResource Gray1}"/>
    <!-- 卡片、弹窗、面板容器背景 -->
    <SolidColorBrush x:Key="BgContainer" Color="{DynamicResource Gray2}"/>
    <!-- 输入框默认白底 -->
    <SolidColorBrush x:Key="BgInput" Color="{DynamicResource Gray0}"/>

    <!-- ====================== 边框、分割线Token ====================== -->
    <!-- 所有控件默认边框 -->
    <SolidColorBrush x:Key="BorderDefault" Color="{DynamicResource Gray4}"/>
    <!-- 全局分割线、卡片内分隔条 -->
    <SolidColorBrush x:Key="SplitLine" Color="{DynamicResource ColorSplitLine}"/>

    <!-- ====================== 悬浮/禁用/遮罩填充Token ====================== -->
    <!-- 列表行、控件悬浮浅底色 -->
    <SolidColorBrush x:Key="BgHover" Color="{DynamicResource FillHover}"/>
    <!-- 禁用控件底层填充色 -->
    <SolidColorBrush x:Key="BgDisabled" Color="{DynamicResource FillDisabled}"/>
    <!-- 弹窗、下拉、抽屉浮层遮罩 -->
    <SolidColorBrush x:Key="MaskOverlay" Color="{DynamicResource MaskColor}"/>
</ResourceDictionary>