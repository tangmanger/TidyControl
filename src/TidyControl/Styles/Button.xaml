<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:buttons="clr-namespace:TidyControl.Buttons"
                    xmlns:attached="clr-namespace:TidyControl.Attached">
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/TidyControl;component/Themes/Theme.xaml"/>
        <ResourceDictionary Source="/TidyControl;component/Styles/Effects.xaml"/>
    </ResourceDictionary.MergedDictionaries>
    <Style x:Key="CommonPathButtonStyle" TargetType="buttons:PathButton">
        <Setter Property="Background" Value="Transparent"></Setter>
        <Setter Property="Fill" Value="{DynamicResource ColorPrimary}"></Setter>
        <Setter Property="BorderThickness" Value="0"></Setter>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="buttons:PathButton">
                    <Border x:Name="border" Background="{TemplateBinding Background}"
                         RenderTransformOrigin="0.5,0.5"
                         BorderBrush="{TemplateBinding BorderBrush}"
                         BorderThickness="{TemplateBinding BorderThickness}"
                         Height="{TemplateBinding Height}"
                         Width="{TemplateBinding Width}"
                         CornerRadius="{TemplateBinding CornerRadius}"
                         Padding="{TemplateBinding Padding}">
                        <StackPanel HorizontalAlignment="Center" Orientation="Horizontal" FlowDirection="{TemplateBinding TextFlowDirection}">
                            <Path Stretch="Uniform" x:Name="PART_Path" Width="{TemplateBinding PathWidth}" Height="{TemplateBinding PathWidth}"  Data="{TemplateBinding PathData}" Fill="{TemplateBinding Fill}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <TextBlock x:Name="PART_TextBlock" Text="{TemplateBinding Text}" Foreground="{TemplateBinding Foreground}" VerticalAlignment="Center" Margin="10,0,0,0"/>
                        </StackPanel>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True" SourceName="border">
                            <Setter Property="Fill" Value="{DynamicResource ColorPrimaryHover}" TargetName="PART_Path"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="RenderTransform" Value="{DynamicResource ScaleTransform}" TargetName="border"/>
                        </Trigger>

                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="BaseButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent"></Setter>
        <Setter Property="BorderThickness" Value="0"></Setter>
        <Setter Property="BorderBrush" Value="Transparent"></Setter>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid>
                        <!--<Border  Background="{TemplateBinding Background}"
                        Height="{TemplateBinding Height}"
                        Width="{TemplateBinding Width}"
                         CornerRadius="{Binding Path=(attached:ButtonAttachedHelper.CornerRadius),RelativeSource={RelativeSource Mode=TemplatedParent}}"
                        Padding="{TemplateBinding Padding}"
                        >
                            <Border.Effect>
                                <DropShadowEffect Color="{DynamicResource Primary6}" Direction="0" ShadowDepth="0" BlurRadius="10"/>
                            </Border.Effect>
                        </Border>-->
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                         RenderTransformOrigin="0.5,0.5"
                         BorderBrush="{TemplateBinding BorderBrush}"
                         BorderThickness="{TemplateBinding BorderThickness}"
                         Height="{TemplateBinding Height}"
                         Width="{TemplateBinding Width}"
                         CornerRadius="{Binding Path=(attached:ButtonAttachedHelper.CornerRadius),RelativeSource={RelativeSource Mode=TemplatedParent}}"
                         Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" Margin="5" VerticalAlignment="Center"/>
                        </Border>
                    </Grid>

                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <Style x:Key="CommonButtonStyle" BasedOn="{StaticResource BaseButtonStyle }" TargetType="Button">
        <Setter Property="Background" Value="{DynamicResource ColorPrimary}"/>
        <Setter Property="Foreground" Value="{DynamicResource TextInverse}"/>
        <Setter Property="attached:ButtonAttachedHelper.CornerRadius" Value="5"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True" >
                <Setter Property="Background" Value="{DynamicResource ColorPrimaryHover}" />
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="{DynamicResource ColorPrimary}" />
            </Trigger>
        </Style.Triggers>
    </Style>
</ResourceDictionary>