<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- =====================================================================================
    【底层色板规范说明】
    1. 本文件仅存储原始色值 Color，不创建 SolidColorBrush，减少内存实例
    2. 色阶统一规则：1=极浅背景 / 5=Hover悬浮 / 6=标准常态 /7=Active点击 /8=按压深色
    3. 切换亮/暗色仅替换本文件，上层ThemeTokens、所有控件样式完全不用修改
    4. 透明色使用 #AARRGGBB 格式，亮色/暗色共用同一套透明色值
    ===================================================================================== -->

    <!-- ====================== 主色 Primary 1~10 梯度 ====================== -->
    <!-- Primary1：主色浅底色，用于标签背景、表格选中行背景 -->
    <Color x:Key="Primary1">#E6F4FF</Color>
    <!-- Primary2：浅主色次要容器底色 -->
    <Color x:Key="Primary2">#BAE7FF</Color>
    <Color x:Key="Primary3">#91CAFF</Color>
    <Color x:Key="Primary4">#69B1FF</Color>
    <!-- Primary5：主色悬浮态 Hover，鼠标移入按钮/输入框使用 -->
    <Color x:Key="Primary5">#4096FF</Color>
    <!-- Primary6：主色标准常态，主按钮、复选框、聚焦边框标准色 -->
    <Color x:Key="Primary6">#1677FF</Color>
    <!-- Primary7：主色激活态 Active，点击、控件聚焦加深色 -->
    <Color x:Key="Primary7">#0958D9</Color>
    <!-- Primary8：主色按压态 Pressed，长按、持续按下深色 -->
    <Color x:Key="Primary8">#003EA6</Color>
    <Color x:Key="Primary9">#002C80</Color>
    <Color x:Key="Primary10">#001D59</Color>

    <!-- ====================== 成功色 Success 1~10 梯度（规则同主色） ====================== -->
    <Color x:Key="Success1">#F0FFF4</Color>
    <Color x:Key="Success2">#D9F7BE</Color>
    <Color x:Key="Success3">#B7EB8F</Color>
    <Color x:Key="Success4">#95DE64</Color>
    <Color x:Key="Success5">#73D13D</Color>
    <!-- Success6：成功标准色，成功提示、图标、按钮 -->
    <Color x:Key="Success6">#52C41A</Color>
    <Color x:Key="Success7">#389E0D</Color>
    <Color x:Key="Success8">#237804</Color>
    <Color x:Key="Success9">#135200</Color>
    <Color x:Key="Success10">#092B00</Color>

    <!-- ====================== 警告色 Warning 1~10 梯度（规则同主色） ====================== -->
    <Color x:Key="Warning1">#FFFBE6</Color>
    <Color x:Key="Warning2">#FFF1B8</Color>
    <Color x:Key="Warning3">#FFE58F</Color>
    <Color x:Key="Warning4">#FFD666</Color>
    <Color x:Key="Warning5">#FFC53D</Color>
    <!-- Warning6：警告标准色，警告提示、图标 -->
    <Color x:Key="Warning6">#FAAD14</Color>
    <Color x:Key="Warning7">#D48806</Color>
    <Color x:Key="Warning8">#AD6B00</Color>
    <Color x:Key="Warning9">#874D00</Color>
    <Color x:Key="Warning10">#613400</Color>

    <!-- ====================== 危险/错误色 Danger 1~10 梯度（规则同主色） ====================== -->
    <Color x:Key="Danger1">#FFF2F0</Color>
    <Color x:Key="Danger2">#FFCCC7</Color>
    <Color x:Key="Danger3">#FFA39E</Color>
    <Color x:Key="Danger4">#FF7875</Color>
    <Color x:Key="Danger5">#FF4D4F</Color>
    <!-- Danger6：错误标准色，报错、删除按钮、校验失败提示 -->
    <Color x:Key="Danger6">#F5222D</Color>
    <Color x:Key="Danger7">#CF1322</Color>
    <Color x:Key="Danger8">#A8071A</Color>
    <Color x:Key="Danger9">#820014</Color>
    <Color x:Key="Danger10">#5C0011</Color>

    <!-- ====================== 中性灰度 Gray0~Gray12 文字/背景分级规范 ====================== -->
    <!-- Gray0 纯白：彩色按钮内部文字、弹窗输入框底色 -->
    <Color x:Key="Gray0">#FFFFFF</Color>
    <!-- Gray1：全局页面根背景色 -->
    <Color x:Key="Gray1">#FAFAFA</Color>
    <!-- Gray2：卡片、弹窗、面板容器背景 -->
    <Color x:Key="Gray2">#F5F5F5</Color>
    <!-- Gray3：输入框悬浮浅背景、次要容器底色 -->
    <Color x:Key="Gray3">#F0F0F0</Color>
    <!-- Gray4：所有控件默认边框、浅分割底色 -->
    <Color x:Key="Gray4">#D9D9D9</Color>
    <!-- Gray5：输入框占位水印、全局禁用状态文字 -->
    <Color x:Key="Gray5">#BFBFBF</Color>
    <!-- Gray6：辅助备注、次要说明文字 -->
    <Color x:Key="Gray6">#8C8C8C</Color>
    <!-- Gray7：正文、表单常规内容文字 -->
    <Color x:Key="Gray7">#595959</Color>
    <!-- Gray8：表单标签、小标题文字 -->
    <Color x:Key="Gray8">#434343</Color>
    <!-- Gray9：大标题、表头、强强调文本 -->
    <Color x:Key="Gray9">#262626</Color>
    <!-- Gray10~Gray12：暗色模式专用深色灰度，亮色极少使用 -->
    <Color x:Key="Gray10">#1F1F1F</Color>
    <Color x:Key="Gray11">#141414</Color>
    <Color x:Key="Gray12">#000000</Color>

    <!-- ====================== 全局透明填充/遮罩（亮色、暗色共用一套） ====================== -->
    <!-- FillLight：极浅填充，轻微底色区分 -->
    <Color x:Key="FillLight">#0A000000</Color>
    <!-- FillHover：列表行、控件悬浮浅底色 -->
    <Color x:Key="FillHover">#0F000000</Color>
    <!-- FillDisabled：禁用控件叠加填充底色 -->
    <Color x:Key="FillDisabled">#1F000000</Color>
    <!-- ColorSplitLine：全局分割线、卡片内分隔条 -->
    <Color x:Key="ColorSplitLine">#14000000</Color>
    <!-- MaskColor：弹窗、下拉、抽屉浮层遮罩 -->
    <Color x:Key="MaskColor">#73000000</Color>
</ResourceDictionary>