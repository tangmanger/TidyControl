<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- =====================================================================================
    【暗色底层色板规范说明】
    1. 所有资源Key命名、数量与Colors.Light.xaml完全一致，仅色值反转适配深色背景
    2. 色彩梯度逻辑反转：1为深色背景底色，10为浅色高亮文字/图标
    3. 灰度分层反转：页面背景使用Gray11深灰，正文文字使用Gray2浅灰，标题使用Gray0纯白
    4. 透明遮罩Alpha色值与亮色完全共用，无需两套区分
    5. 切换主题仅替换本文件，上层ThemeTokens、控件样式无需任何修改
    ===================================================================================== -->

    <!-- ====================== 主色 Primary 1~10 暗色梯度 ====================== -->
    <!-- Primary1：深色页面主色浅容器背景（深色模式标签/选中行底色） -->
    <Color x:Key="Primary1">#11243D</Color>
    <Color x:Key="Primary2">#15395E</Color>
    <Color x:Key="Primary3">#194B7A</Color>
    <Color x:Key="Primary4">#1D5991</Color>
    <!-- Primary5：深色模式主色悬浮Hover -->
    <Color x:Key="Primary5">#2270B9</Color>
    <!-- Primary6：深色模式标准主色，按钮、聚焦边框、图标 -->
    <Color x:Key="Primary6">#177DDC</Color>
    <!-- Primary7：深色模式点击激活Active加深 -->
    <Color x:Key="Primary7">#3391E8</Color>
    <!-- Primary8：深色模式按压Pressed高亮浅色 -->
    <Color x:Key="Primary8">#54A8F8</Color>
    <Color x:Key="Primary9">#85C4FF</Color>
    <!-- Primary10：深色模式主色高亮文字/图标 -->
    <Color x:Key="Primary10">#B3D9FF</Color>

    <!-- ====================== 成功色 Success 1~10 暗色梯度（规则同主色） ====================== -->
    <Color x:Key="Success1">#162312</Color>
    <Color x:Key="Success2">#1C3617</Color>
    <Color x:Key="Success3">#24491C</Color>
    <Color x:Key="Success4">#2D5E23</Color>
    <Color x:Key="Success5">#38732B</Color>
    <!-- Success6：深色模式标准成功色，提示、图标、按钮 -->
    <Color x:Key="Success6">#49A833</Color>
    <Color x:Key="Success7">#62C248</Color>
    <Color x:Key="Success8">#86D46F</Color>
    <Color x:Key="Success9">#B0E39E</Color>
    <Color x:Key="Success10">#D6F1CC</Color>

    <!-- ====================== 警告色 Warning 1~10 暗色梯度（规则同主色） ====================== -->
    <Color x:Key="Warning1">#2B2111</Color>
    <Color x:Key="Warning2">#423216</Color>
    <Color x:Key="Warning3">#59431A</Color>
    <Color x:Key="Warning4">#70541F</Color>
    <Color x:Key="Warning5">#8C6827</Color>
    <!-- Warning6：深色模式标准警告色 -->
    <Color x:Key="Warning6">#D48806</Color>
    <Color x:Key="Warning7">#FAAD14</Color>
    <Color x:Key="Warning8">#FFC53D</Color>
    <Color x:Key="Warning9">#FFD666</Color>
    <Color x:Key="Warning10">#FFE58F</Color>

    <!-- ====================== 危险/错误色 Danger 1~10 暗色梯度（规则同主色） ====================== -->
    <Color x:Key="Danger1">#2E1412</Color>
    <Color x:Key="Danger2">#471A17</Color>
    <Color x:Key="Danger3">#5F201C</Color>
    <Color x:Key="Danger4">#782722</Color>
    <Color x:Key="Danger5">#94302A</Color>
    <!-- Danger6：深色模式标准错误色，报错、删除按钮 -->
    <Color x:Key="Danger6">#E53E3E</Color>
    <Color x:Key="Danger7">#FF4D4F</Color>
    <Color x:Key="Danger8">#FF7875</Color>
    <Color x:Key="Danger9">#FFA39E</Color>
    <Color x:Key="Danger10">#FFCCC7</Color>

    <!-- ====================== 暗色中性灰度 Gray0~Gray12 分层规范 ====================== -->
    <!-- Gray0 纯白：深色模式标题、强强调文字、彩色按钮内文字 -->
    <Color x:Key="Gray0">#FFFFFF</Color>
    <!-- Gray1：一级正文高亮文本 -->
    <Color x:Key="Gray1">#E5E5E5</Color>
    <!-- Gray2：深色模式常规正文文字（对应亮色Gray7） -->
    <Color x:Key="Gray2">#D1D1D1</Color>
    <!-- Gray3：辅助说明、次要文本（对应亮色Gray6） -->
    <Color x:Key="Gray3">#ABABAB</Color>
    <!-- Gray4：深色模式控件边框、分割线底色（对应亮色Gray4） -->
    <Color x:Key="Gray4">#7A7A7A</Color>
    <!-- Gray5：输入框占位水印、禁用文字（对应亮色Gray5） -->
    <Color x:Key="Gray5">#595959</Color>
    <!-- Gray6：次要边框、浅分割底色 -->
    <Color x:Key="Gray6">#4A4A4A</Color>
    <!-- Gray7：输入框悬浮背景底色 -->
    <Color x:Key="Gray7">#3A3A3A</Color>
    <!-- Gray8：卡片悬浮浅底色 -->
    <Color x:Key="Gray8">#2F2F2F</Color>
    <!-- Gray9：次要面板容器背景 -->
    <Color x:Key="Gray9">#262626</Color>
    <!-- Gray10：卡片、弹窗容器背景（对应亮色Gray2） -->
    <Color x:Key="Gray10">#1F1F1F</Color>
    <!-- Gray11：全局页面根背景（对应亮色Gray1） -->
    <Color x:Key="Gray11">#141414</Color>
    <!-- Gray12：纯黑，极少使用 -->
    <Color x:Key="Gray12">#000000</Color>

    <!-- ====================== 全局透明填充/遮罩（亮暗两套共用，无需修改） ====================== -->
    <!-- FillLight：极浅填充，轻微底色区分 -->
    <Color x:Key="FillLight">#0A000000</Color>
    <!-- FillHover：列表行、控件悬浮浅底色 -->
    <Color x:Key="FillHover">#0F000000</Color>
    <!-- FillDisabled：禁用控件叠加填充底色 -->
    <Color x:Key="FillDisabled">#1F000000</Color>
    <!-- ColorSplitLine：全局分割线、卡片内分隔条 -->
    <Color x:Key="ColorSplitLine">#14000000</Color>
    <!-- MaskColor：弹窗、下拉、抽屉浮层遮罩 -->
    <Color x:Key="MaskColor">#73000000</Color>
</ResourceDictionary>